    "from tqdm import tqdm\n",
    "import torch\n",
    "import matplotlib.pyplot as plt\n",
    "import numpy as np\n",
    "import pandas as pd\n",
    "import geopandas as gpd\n",
    "\n",
    "def get_neuron_scores(z, neuron_id):\n",
    "    scores = z[:, neuron_id].detach().cpu().numpy()\n",
    "    return scores\n",
    "\n",
    "\"\"\"\n",
    "=========   PLOT NEURON   =========\n",
    "\"\"\"\n",
    "def plot_neuron(\n",
    "    df,\n",
    "    z,\n",
    "    neuron_id,\n",
    "    figsize=(10, 10),\n",
    "    top_k=None,\n",
    "):\n",
    "    scores = get_neuron_scores(z, neuron_id)\n",
    "\n",
    "    work_df = df.copy()\n",
    "    work_df[\"score\"] = scores\n",
    "\n",
    "    if top_k is not None:\n",
    "        work_df = (\n",
    "            work_df\n",
    "            .sort_values(\"score\", ascending=False)\n",
    "            .head(top_k)\n",
    "        )\n",
    "\n",
    "    gdf = gpd.GeoDataFrame(\n",
    "        work_df,\n",
    "        geometry=gpd.points_from_xy(\n",
    "            work_df[\"longitude\"],\n",
    "            work_df[\"latitude\"]\n",
    "        ),\n",
    "        crs=\"EPSG:4326\"\n",
    "    )\n",
    "\n",
    "    # Use the same CRS as your Moran plot\n",
    "    gdf = gdf.to_crs(\"EPSG:3857\")\n",
    "\n",
    "    fig, ax = plt.subplots(figsize=figsize)\n",
    "\n",
    "    high = gdf[gdf[\"score\"] > 0.5]\n",
    "    low = gdf[gdf[\"score\"] <= 0.5]\n",
    "\n",
    "    if len(low):\n",
    "        low.plot(\n",
    "            ax=ax,\n",
    "            column=\"score\",\n",
    "            cmap=\"viridis\",\n",
    "            markersize=0.5,\n",
    "            alpha=0.5,\n",
    "            legend=False,\n",
    "        )\n",
    "\n",
    "    if len(high):\n",
    "        high.plot(\n",
    "            ax=ax,\n",
    "            column=\"score\",\n",
    "            cmap=\"viridis\",\n",
    "            markersize=2,\n",
    "            alpha=1.0,\n",
    "            legend=False,\n",
    "        )\n",
    "\n",
    "    # Create a colorbar matching the score range\n",
    "    norm = plt.Normalize(\n",
    "        vmin=gdf[\"score\"].min(),\n",
    "        vmax=gdf[\"score\"].max()\n",
    "    )\n",
    "\n",
    "    sm = plt.cm.ScalarMappable(\n",
    "        cmap=\"viridis\",\n",
    "        norm=norm\n",
    "    )\n",
    "    sm.set_array([])\n",
    "\n",
    "    plt.colorbar(\n",
    "        sm,\n",
    "        ax=ax,\n",
    "        label=\"Neuron activation\",\n",
    "        shrink=0.5\n",
    "    )\n",
    "\n",
    "    ax.set_title(\n",
    "        f\"Neuron {neuron_id} activations\"\n",
    "    )\n",
    "\n",
    "    ax.set_axis_off()\n",
    "\n",
    "    plt.show()"
   ]
